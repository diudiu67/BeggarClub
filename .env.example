# Discord bot token (from discord.com/developers)
DISCORD_TOKEN=your_discord_token_here

# YouTube Data API v3 key (from console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Secret used by the web UI to authenticate with the backend
# Change this to any random string
WEB_SECRET=changeme123

# Where your frontend is hosted (for CORS)
# Local development:
FRONTEND_URL=http://localhost:5173
# Production (set to your Vercel URL after deploying):
# FRONTEND_URL=https://your-app.vercel.app
